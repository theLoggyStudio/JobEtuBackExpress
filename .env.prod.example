# Copier vers `.env.prod` — ne pas y mettre de secrets dans ce fichier d’exemple (placeholders uniquement).
# Sur Vercel : les variables du dashboard remplacent `.env.prod`.

# Optionnel sur Vercel (non utilisé sans app.listen). Utile en local / VPS : `npm start` → défaut 4000 si absent.
# PORT=4000

NODE_ENV=production
STORAGE_DRIVER=postgres
DB_SYNC=false
JSON_STORE_PATH=data/jobetu-test-store.json

JWT_SECRET=remplacer_par_une_chaine_longue_et_aleatoire
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10
CORS_ORIGIN=https://job-etu.vercel.app
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=30
PAYLOAD_LIMIT=1mb
ADMIN_EMAIL=admin@votredomaine.sn
ADMIN_PASSWORD=definir_mot_de_passe_fort
FRONTEND_APP_URL=https://job-etu.vercel.app
API_PUBLIC_URL=https://job-etu-back-express.vercel.app
PAYDUNYA_CALLBACK_URL=https://job-etu.vercel.app/paydunia/hasPaied
PAYDUNYA_MODE=test
PAYDUNYA_SUBMISSION_AMOUNT=2500
PAYDUNYA_STORE_NAME=JobEtu
PAYDUNYA_MASTER_KEY=
PAYDUNYA_TEST_PRIVATE_KEY=
PAYDUNYA_TEST_PUBLIC_KEY=
PAYDUNYA_TEST_TOKEN=
PAYDUNYA_LIVE_PRIVATE_KEY=
PAYDUNYA_LIVE_PUBLIC_KEY=
PAYDUNYA_LIVE_TOKEN=

# DATABASE_URL= ou POSTGRES_URL= (Vercel Postgres / Neon)
