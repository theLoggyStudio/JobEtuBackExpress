# Copier vers `.env.prod` — utilisé quand MODE_CONFIG.current === 'production' (mode.constant.ts)
# Ne pas committer `.env.prod` (secrets). Sur Vercel, les variables du dashboard remplacent souvent ce fichier.

PORT=4000
NODE_ENV=production
STORAGE_DRIVER=postgres
DB_SYNC=false
JSON_STORE_PATH=data/jobetu-test-store.json
JWT_SECRET=remplacer_par_une_chaine_longue_et_secrete
JWT_EXPIRES_IN=7d
CORS_ORIGIN=https://votre-front.vercel.app
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=30
PAYLOAD_LIMIT=1mb
# CLIENT_PAYLOAD_AES_KEY=
ADMIN_EMAIL=admin@votredomaine.sn
ADMIN_PASSWORD=definir_mot_de_passe_fort

PAYDUNYA_MASTER_KEY=
PAYDUNYA_TEST_PRIVATE_KEY=
PAYDUNYA_TEST_PPUBLIC_KEY=
PAYDUNYA_TEST_PTOKEN=
PAYDUNYA_LIVE_PRIVATE_KEY=
PAYDUNYA_LIVE_PUBLIC_KEY=
PAYDUNYA_LIVE_TOKEN=
PAYDUNYA_MODE=test
PAYDUNYA_SUBMISSION_AMOUNT=2500
PAYDUNYA_STORE_NAME=JobEtu
FRONTEND_APP_URL=https://votre-front.vercel.app
API_PUBLIC_URL=https://votre-api.vercel.app
PAYDUNYA_CALLBACK_URL=https://votre-front.vercel.app/paydunia/hasPaied

# Vercel Postgres / Neon (exemples — ne pas mettre de vrais secrets ici)
# DATABASE_URL=
# POSTGRES_URL=
# POSTGRES_USER= POSTGRES_HOST= POSTGRES_PASSWORD= POSTGRES_DATABASE=
