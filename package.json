{
  "name": "jobetu-back",
  "version": "0.1.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:memory": "cross-env STORAGE_DRIVER=memory tsx watch src/server.ts",
    "dev:json": "cross-env STORAGE_DRIVER=json tsx watch src/server.ts",
    "build": "tsc && node scripts/obfuscate.mjs",
    "build:plain": "tsc",
    "start": "node dist/server.js",
    "seed:admin": "tsx src/scripts/seedAdmin.ts",
    "build:obfuscate": "tsc && node scripts/obfuscate.mjs"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.5",
    "serverless-http": "^3.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "javascript-obfuscator": "^4.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
