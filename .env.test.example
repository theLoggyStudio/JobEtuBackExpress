# Copier vers `.env.test` — utilisé quand MODE_CONFIG.current === 'test' (mode.constant.ts)
# Pas de suffixe _TEST obligatoire ici : le fichier est déjà réservé au test (FOO_TEST reste supporté si besoin).

PORT=4000
NODE_ENV=development
STORAGE_DRIVER=postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/jobetu
DB_SYNC=true
JSON_STORE_PATH=data/jobetu-test-store.json
JWT_SECRET=dev-only-change-me
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=30
PAYLOAD_LIMIT=1mb
# CLIENT_PAYLOAD_AES_KEY=
ADMIN_EMAIL=admin@jobetu.local
ADMIN_PASSWORD=AdminJobEtu!2026

PAYDUNYA_MASTER_KEY=
PAYDUNYA_TEST_PRIVATE_KEY=
PAYDUNYA_TEST_PPUBLIC_KEY=
PAYDUNYA_TEST_PTOKEN=
PAYDUNYA_LIVE_PRIVATE_KEY=
PAYDUNYA_LIVE_PUBLIC_KEY=
PAYDUNYA_LIVE_TOKEN=
PAYDUNYA_MODE=test
PAYDUNYA_SUBMISSION_AMOUNT=2500
PAYDUNYA_STORE_NAME=JobEtu
FRONTEND_APP_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:4000
