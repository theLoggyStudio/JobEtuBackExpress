PORT=4000
NODE_ENV=development
# postgres | memory | json — memory/json = sans DATABASE_URL (RAM reset au reboot, ou fichier JSON)
STORAGE_DRIVER=postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/jobetu
DB_SYNC=true
# Chemin du store JSON si STORAGE_DRIVER=json (relatif au cwd)
# JSON_STORE_PATH=data/jobetu-test-store.json
JWT_SECRET=remplacer_par_une_chaine_longue_et_secrete
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=30
PAYLOAD_LIMIT=1mb
# Optionnel : AES-256 en hex (64 caractères), identique à VITE_CLIENT_PAYLOAD_AES_KEY sur le front — chiffre les mots de passe dans le corps JSON (complément au HTTPS).
# CLIENT_PAYLOAD_AES_KEY=
# Défauts identiques à `Constants/mode.constant.ts` → `TEST_DEFAULT_ADMIN_CONFIG`
ADMIN_EMAIL=admin@jobetu.local
ADMIN_PASSWORD=AdminJobEtu!2026

# --- PayDunya (soumission questionnaire, 2500 FCFA par défaut) ---
# Sans master + private + token, l’API renvoie 501 sur /submissions/paydunya/init et accepte encore POST /submissions direct.
PAYDUNYA_MASTER_KEY=
PAYDUNYA_TEST_PRIVATE_KEY=
PAYDUNYA_TEST_PPUBLIC_KEY=
PAYDUNYA_TEST_PTOKEN=
# En production (PAYDUNYA_MODE=live), utiliser plutôt :
PAYDUNYA_LIVE_PRIVATE_KEY=
PAYDUNYA_LIVE_PUBLIC_KEY=
PAYDUNYA_LIVE_TOKEN=

# test | live
PAYDUNYA_MODE=test
PAYDUNYA_SUBMISSION_AMOUNT=2500
PAYDUNYA_STORE_NAME=JobEtu
# URL du front (return_url / cancel_url), sans slash final
FRONTEND_APP_URL=http://localhost:5173
# URL publique de cette API pour l’IPN (ngrok en dev), sans slash final
API_PUBLIC_URL=http://localhost:4000
